  "devDependencies": {
    "brittle": "^3.0.0",
    "prettier": "^3.6.2",
    "prettier-config-holepunch": "^1.0.0"
  },
  "scripts": {
    "format": "prettier . --write",
    "test": "prettier . --check && brittle test.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/compact-encoding/compact-encoding.git"
  },
  "author": "Mathias Buus (@mafintosh)",
  "license": "Apache-2.0",
  "bugs": {
