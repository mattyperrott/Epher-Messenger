versal/index.js":{"offset":550555,"length":42,"mode":420},"/node_modules/sodium-universal/package.json":{"offset":550597,"length":1217,"mode":420},"/node_modules/streamx/index.js":{"offset":551814,"length":33350,"mode":420},"/node_modules/streamx/package.json":{"offset":585164,"length":836,"mode":420},"/node_modules/text-decoder/index.js":{"offset":586000,"length":1371,"mode":420},"/node_modules/text-decoder/lib/pass-through-decoder.js":{"offset":587371,"length":269,"mode":420},"/node_modules/text-decoder/lib/utf8-decoder.js":{"offset":587640,"length":4429,"mode":420},"/node_modules/text-decoder/package.json":{"offset":592069,"length":990,"mode":420},"/node_modules/time-ordered-set/index.js":{"offset":593059,"length":1444,"mode":420},"/node_modules/time-ordered-set/package.json":{"offset":594503,"length":666,"mode":420},"/node_modules/timeout-refresh/browser.js":{"offset":595169,"length":1098,"mode":420},"/node_modules/timeout-refresh/index.js":{"offset":596267,"length":184,"mode":420},"/node_modules/timeout-refresh/node.js":{"offset":596451,"length":928,"mode":420},"/node_modules/timeout-refresh/package.json":{"offset":597379,"length":619,"mode":420},"/node_modules/udx-native/binding.js":{"offset":597998,"length":90,"mode":420},"/node_modules/udx-native/lib/ip.js":{"offset":598088,"length":2204,"mode":420},"/node_modules/udx-native/lib/network-interfaces.js":{"offset":600292,"length":1341,"mode":420},"/node_modules/udx-native/lib/socket.js":{"offset":601633,"length":7557,"mode":420},"/node_modules/udx-native/lib/stream.js":{"offset":609190,"length":12706,"mode":420},"/node_modules/udx-native/lib/udx.js":{"offset":621896,"length":2868,"mode":420},"/node_modules/udx-native/package.json":{"offset":624764,"length":1615,"mode":420},"/node_modules/unordered-set/index.js":{"offset":626379,"length":677,"mode":420},"/node_modules/unordered-set/package.json":{"offset":627056,"length":654,"mode":420},"/node_modules/unslab/index.js":{"offset":627710,"length":913,"mode":420},"/node_modules/unslab/package.json":{"offset":628623,"length":613,"mode":420},"/node_modules/which-runtime/index.js":{"offset":629236,"length":1231,"mode":420},"/node_modules/which-runtime/package.json":{"offset":630467,"length":602,"mode":420},"/node_modules/xache/index.js":{"offset":631069,"length":2378,"mode":420},"/node_modules/xache/package.json":{"offset":633447,"length":584,"mode":420},"/node_modules/z32/index.js":{"offset":634031,"length":2654,"mode":420},"/node_modules/z32/package.json":{"offset":636685,"length":701,"mode":420},"/package.json":{"offset":637386,"length":250,"mode":420},"/src/p2p-runtime.js":{"offset":637636,"length":23732,"mode":420}}}
const { Pull, Push, HEADERBYTES, KEYBYTES, ABYTES } = require('sodium-secretstream')
const sodium = require('sodium-universal')
const crypto = require('hypercore-crypto')
const { Duplex, Writable, getStreamError } = require('streamx')
const b4a = require('b4a')
const Timeout = require('timeout-refresh')
const unslab = require('unslab')
const Bridge = require('./lib/bridge')
const Handshake = require('./lib/handshake')

const IDHEADERBYTES = HEADERBYTES + 32
const [NS_INITIATOR, NS_RESPONDER, NS_SEND] = crypto.namespace('hyperswarm/secret-stream', 3)
const MAX_ATOMIC_WRITE = 256 * 256 * 256 - 1

module.exports = class NoiseSecretStream extends Duplex {
  constructor(isInitiator, rawStream, opts = {}) {
    super({ mapWritable: toBuffer })

    if (typeof isInitiator !== 'boolean') {
      throw new Error('isInitiator should be a boolean')
    }

    this.noiseStream = this
    this.isInitiator = isInitiator
    this.rawStream = null

    this.publicKey = opts.publicKey || null
    this.remotePublicKey = opts.remotePublicKey || null
    this.handshakeHash = null
    this.connected = false
    this.keepAlive = opts.keepAlive || 0
    this.timeout = 0
    this.enableSend = opts.enableSend !== false

    // pointer for upstream to set data here if they want
    this.userData = null

    let openedDone = null
    this.opened = new Promise((resolve) => {
      openedDone = resolve
    })

    this.rawBytesWritten = 0
    this.rawBytesRead = 0

    // metadata used by 'hyperdht'
    this.relay = null
    this.puncher = null

    // unwrapped raw stream
    this._rawStream = null

    // handshake state
    this._handshake = null
    this._handshakePattern = opts.pattern || null
    this._handshakeDone = null

    // message parsing state
    this._state = 0
    this._len = 0
    this._tmp = 1
    this._message = null

    this._openedDone = openedDone
    this._startDone = null
    this._drainDone = null
    this._outgoingPlain = null
    this._outgoingWrapped = null
    this._utp = null
    this._setup = true
    this._ended = 2
    this._encrypt = null
    this._decrypt = null
    this._timeoutTimer = null
    this._keepAliveTimer = null
    this._sendState = null

    if (opts.autoStart !== false) this.start(rawStream, opts)

    // wiggle it to trigger open immediately (TODO add streamx option for this)
    this.resume()
    this.pause()
  }

  static keyPair(seed) {
    return Handshake.keyPair(seed)
  }

  static id(handshakeHash, isInitiator, id) {
    return streamId(handshakeHash, isInitiator, id)
